    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;    `ID`,&#xD;&#xA;  `CDP_Consumption_Table_Name`,&#xD;&#xA;  `Staging_TableName`,&#xD;&#xA;  `CA_QUERY`,&#xD;&#xA;  `Ready_To_Execute`,&#xD;&#xA;  `CDP_Consumption_Schema` ,&#xD;&#xA;  `Load_Type` ,&#xD;&#xA;  `US_QUERY` ,&#xD;&#xA;`US_COUNT`,&#xD;&#xA;`CA_COUNT`&#xD;&#xA;from SC_STAGING_TO_CONSUMPTION&#xD;&#xA; WHERE Ready_To_Execute = &quot; + context.IsActive + &quot; &quot; +&#xD;&#xA;    context.whereclauseand + &quot; &quot; +&#xD;&#xA;    &quot;AND CDP_Consumption_Table_Name  NOT IN ( &quot; +&#xD;&#xA;    &quot;  SELECT TGT_ASSET_TXT &quot; +&#xD;&#xA;    &quot;  FROM &quot; + context.SC_Metadata_DB + &quot;.AUD_EXEC_LOG &quot; +&#xD;&#xA;    &quot;  WHERE DATA_PIPLN_ID = '&quot; + ((String)globalMap.get(&quot;DATA_PIPLN_ID&quot;)) + &quot;' &quot; +&#xD;&#xA;    &quot;    AND data_date = '&quot; + context.Datadate + &quot;' &quot; +&#xD;&#xA;    &quot;    AND RSLT_DESC = 'Pass' &quot; +&#xD;&#xA;&quot;    AND Job_Name = '&quot; + context.Id_Job_Name + &quot;' &quot; +&#xD;&#xA;    &quot;)&quot;&#xD;&#xA;"/>
