  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1760" posY="960">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_5" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="//Code generated according to input schema and output schema&#xA;context.Target_Count = input_row.count;&#xA;&#xA;System.out.println(&quot;Target_Count&quot;+context.Target_Count);&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;// Build path for this iteration&#xA;String currentPath = (String)globalMap.get(&quot;row1.Staging_TableName&quot;);&#xA;&#xA;// Get CA_COUNT and US_COUNT from globalMap&#xA;String caCount = (String)globalMap.get(&quot;row1.CA_COUNT&quot;);&#xA;System.out.println(&quot;CA query: &quot; +(String)globalMap.get(&quot;row1.CA_COUNT&quot;));&#xA;String usCount = (String)globalMap.get(&quot;row1.US_COUNT&quot;);&#xA;System.out.println(&quot;US query: &quot; +(String)globalMap.get(&quot;row1.US_COUNT&quot;));&#xA;&#xA;// Check CA_COUNT&#xA;if (caCount != null &amp;&amp; caCount.length() > 9) {&#xA;    if (context.CA_Path == null || context.CA_Path.isEmpty()) {&#xA;        context.CA_Path = &quot;hsi_staging_ca.&quot; + currentPath;&#xA;    } else {&#xA;        context.CA_Path += &quot;,&quot; + currentPath;&#xA;    }&#xA;    context.CA_Country = &quot;CA&quot;;&#xA;    System.out.println(&quot;CA iteration path: &quot; + currentPath);&#xA;}&#xA;&#xA;// Check US_COUNT&#xA;if (usCount != null &amp;&amp; usCount.length() > 9) {&#xA;    if (context.US_Path == null || context.US_Path.isEmpty()) {&#xA;        context.US_Path = &quot;hsi_staging.&quot; + currentPath;&#xA;    } else {&#xA;        context.US_Path += &quot;,&quot; + currentPath;&#xA;    }&#xA;    context.US_Country = &quot;US&quot;;&#xA;    System.out.println(&quot;US iteration path: &quot; + currentPath);&#xA;}&#xA;&#xA;// Print final paths&#xA;System.out.println(&quot;Current CA path: &quot; + context.CA_Path);&#xA;System.out.println(&quot;Current US path: &quot; + context.US_Path);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_5">
      <column comment="" key="false" length="-1" name="count" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
    </metadata>
  </node>
