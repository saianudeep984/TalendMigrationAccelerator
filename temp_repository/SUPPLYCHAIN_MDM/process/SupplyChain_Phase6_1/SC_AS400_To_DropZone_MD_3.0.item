    <elementParameter field="MEMO_SQL" name="QUERY" value="    &quot;SELECT &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Sno, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.PhaseNo, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Is_Active, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Get_columns, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.AS400_Schema, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Country, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.AS400_FileName, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Filename, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Table_Name, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.LoadType, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.Delimter, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.AS400_System, &quot; +&#xD;&#xA;    &quot;  SC_AS400_To_DropZone.AS400_Host &quot; +&#xD;&#xA;    &quot;FROM SC_AS400_To_DropZone &quot; +&#xD;&#xA;    &quot;WHERE SC_AS400_To_DropZone.Is_Active = '&quot; + context.Is_Active + &quot;' &quot; +&#xD;&#xA;    &quot;AND SC_AS400_To_DropZone.Country &quot; + context.Country + &quot; &quot; +  // context.Country should be like &quot;IN ('us','ca')&quot;&#xD;&#xA;    context.whereclauseand + &quot; &quot; +&#xD;&#xA;    &quot;AND SC_AS400_To_DropZone.FileName NOT IN ( &quot; +&#xD;&#xA;    &quot;  SELECT SRC_ASSET_TXT &quot; +&#xD;&#xA;    &quot;  FROM &quot; + context.SC_Metadata_DB + &quot;.AUD_EXEC_LOG &quot; +&#xD;&#xA;    &quot;  WHERE DATA_PIPLN_ID = '&quot; + globalMap.get(&quot;DATA_PIPLN_ID&quot;) + &quot;' &quot; +&#xD;&#xA;    &quot;    AND data_date = '&quot; + context.Datadate + &quot;' &quot; +&#xD;&#xA;    &quot;    AND RSLT_DESC = 'Pass1' &quot; +&#xD;&#xA;    &quot;    AND Job_Name = '&quot; + context.Id_Job_Name + &quot;' &quot; +&#xD;&#xA;    &quot;)&quot;&#xD;&#xA;"/>
