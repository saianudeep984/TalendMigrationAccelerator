    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT distinct &#xD;&#xA;  `nlgi_customers`.`Type_of_Insurance`, &#xD;&#xA;  `nlgi_customers`.`LOB`, &#xD;&#xA;  `nlgi_customers`.`Module`, &#xD;&#xA;  `nlgi_customers`.`CustomerID`, &#xD;&#xA;  `nlgi_customers`.`Cover_From`, &#xD;&#xA;  `nlgi_customers`.`Cover_To`, &#xD;&#xA;  `nlgi_customers`.`Customer_Name`, &#xD;&#xA;  `nlgi_customers`.`Prefix`, &#xD;&#xA;  `nlgi_customers`.`First_Name`, &#xD;&#xA;  `nlgi_customers`.`Second_Name`, &#xD;&#xA;  `nlgi_customers`.`Last_Name`, &#xD;&#xA;  `nlgi_customers`.`DOB`, &#xD;&#xA;  `nlgi_customers`.`Gender`, &#xD;&#xA;  `nlgi_customers`.`Nationality`, &#xD;&#xA;  `nlgi_customers`.`Civil_No`, &#xD;&#xA;  `nlgi_customers`.`Passport_No`, &#xD;&#xA;  `nlgi_customers`.`Mobile`, &#xD;&#xA;  `nlgi_customers`.`Email`, &#xD;&#xA;  `nlgi_customers`.`Rules`&#xD;&#xA;FROM `nlgi_customers`&#xD;&#xA;WHERE Status = 'New'&#xD;&#xA;&quot;"/>
