    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;  0 AS GR_ID,&#xA;  `nlgi_customers`.`Type_of_Insurance`, &#xA;  `nlgi_customers`.`LOB`, &#xA;  `nlgi_customers`.`Module`, &#xA;  `nlgi_customers`.`Cover_From`, &#xA;  `nlgi_customers`.`Cover_To`, &#xA;  `nlgi_customers`.`Customer_Name`, &#xA;  `nlgi_customers`.`Prefix`, &#xA;  `nlgi_customers`.`First_Name`, &#xA;  `nlgi_customers`.`Second_Name`, &#xA;  `nlgi_customers`.`Last_Name`, &#xA;  `nlgi_customers`.`DOB`, &#xA;  `nlgi_customers`.`Civil_No`, &#xA;  `nlgi_customers`.`Passport_No`, &#xA;  `nlgi_customers`.`Mobile`, &#xA;  `nlgi_customers`.`Email`, &#xA;  `nlgi_customers`.`Rules`, &#xA;  `nlgi_customers`.`ValidationDate`, &#xA;  `nlgi_customers`.`Status`, &#xA;  `nlgi_customers`.`CustomerID`, &#xA;  `nlgi_customers`.`Gender`, &#xA;  `nlgi_customers`.`Nationality`&#xA;FROM `nlgi_customers`&#xD;&#xA;WHERE status = 'Clean'&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
