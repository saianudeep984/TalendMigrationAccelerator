    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;&#x9;MAX(&quot;+context.golden_record_indentifier_column+&quot;) AS MDM_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Customer_Name' THEN COLUMN_VALUE ELSE NULL END) Customer_Name,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Prefix' THEN COLUMN_VALUE ELSE NULL END) Prefix,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'FirstName' THEN COLUMN_VALUE ELSE NULL END) AS FirstName,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'MiddleName' THEN COLUMN_VALUE ELSE NULL END) MiddleName,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'LastName' THEN COLUMN_VALUE ELSE NULL END) MiddleName,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Date_Of_Birth' THEN COLUMN_VALUE ELSE NULL END) Date_Of_Birth,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'SSN' THEN COLUMN_VALUE ELSE NULL END) SSN,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Passport_No' THEN COLUMN_VALUE ELSE NULL END) AS Passport_No,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Gender' THEN COLUMN_VALUE ELSE NULL END) Gender,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Nationality' THEN COLUMN_VALUE ELSE NULL END) Nationality,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'Status' THEN COLUMN_VALUE ELSE NULL END) Status,&#xD;&#xA;&#x9;GID&#xD;&#xA;FROM tmp_CMF_Value&#xD;&#xA;WHERE (&#xD;&#xA;&#x9;&#x9;'&quot;+context.Rule_Name + &quot;' = 'Cust_WithNoGR' or &quot; + context.golden_record_indentifier_column+&quot; IS NOT NULL )&#xD;&#xA; GROUP BY GID&#xD;&#xA;&quot;"/>
