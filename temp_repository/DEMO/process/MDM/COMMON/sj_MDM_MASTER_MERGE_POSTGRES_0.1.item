    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:5QTpJQgF23FCPvBcVBLBoD6BiZVlM6PyPfS+wjcZC0COKAju+ida9eyKY/a36LrHBwZi/eCZDnNPGsCd7Q==" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="/****** Script for SelectTopNRows command from SSMS  ******/&#xD;&#xA;&quot;&#xD;&#xA;SELECT distinct&#xD;&#xA;&#x9;   FUNC&#xD;&#xA;      ,\&quot;ORDER\&quot;&#xD;&#xA;     ,REFERENCE_COLUMN&#xD;&#xA;      ,VALUE&#xD;&#xA;&#x9; ,TARGET_COLUMN      &#xD;&#xA;    &#x9;,IGNORE_BLANKS&#xD;&#xA;      ,REFERENCE_ACTUAL_FIELD&#xD;&#xA;      ,TARGET_ACTUAL_FIELD&#xD;&#xA;&#x9;  ,datatype REFCOL_DATA_TYPE&#xD;&#xA;&#x9;  ,sequence_order&#xD;&#xA;FROM &#xD;&#xA;&#x9;MDM.datamodel dm &#xD;&#xA;&#x9;inner join&#xD;&#xA;&#x9;MDM.job_merging_configuration s on&#xD;&#xA;&#x9;&#x9;DATAMODEL_ID = dm.id&#xD;&#xA;&#x9;inner join &#xD;&#xA;&#x9;(&#x9;&#x9;select &#x9;d.id , ma.attributename, ma.datatype &#xD;&#xA;&#x9;&#x9;from &#xD;&#xA;&#x9;&#x9;&#x9;MDM.datamodel d &#xD;&#xA;&#x9;&#x9;&#x9;inner join &#xD;&#xA;&#x9;&#x9;&#x9;MDM.model m on &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;m.datamodelid =d.stagingdatamodelid&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;inner join&#xD;&#xA;&#x9;&#x9;&#x9;MDM.modelattributes ma on &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;ma.modelid = m.id&#xD;&#xA;&#x9;) ma on &#xD;&#xA;&#x9;&#x9;ma.id = dm.id and &#xD;&#xA;&#x9;&#x9;ma.attributename = s.REFERENCE_COLUMN  &#xD;&#xA;&#x9;inner join MDM.job_merge_rule mr on&#xD;&#xA;&#x9;&#x9;mr.id = s.rule_id&#xD;&#xA;where &#x9;dm.\&quot;name\&quot; = '&quot;  +  context.Data_Model_Name  + &quot;'  &#xD;&#xA;&#x9;and &#xD;&#xA;&#x9;mr.rulename like'&quot;  +  context.Rule_Name   + &quot;%'&#xD;&#xA;order by s.sequence_order&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="postgres_id" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="CHECK" name="USE_CURSOR" value="false"/>
    <elementParameter field="TEXT" name="CURSOR_SIZE" value="1000" show="false"/>
    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="FUNC" id="0"/>
      <elementValue elementRef="TRIM" value="false" id="1"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="ORDER_NAME" id="2"/>
      <elementValue elementRef="TRIM" value="false" id="3"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="REF_COLUMN" id="4"/>
      <elementValue elementRef="TRIM" value="false" id="5"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="VALUE" id="6"/>
      <elementValue elementRef="TRIM" value="false" id="7"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="TARGET_COLUMN" id="8"/>
      <elementValue elementRef="TRIM" value="false" id="9"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="IGNORE_BLANKS" id="10"/>
      <elementValue elementRef="TRIM" value="false" id="11"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="REFERENCE_ACTUAL_FIELD" id="12"/>
      <elementValue elementRef="TRIM" value="false" id="13"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="TARGET_ACTUAL_FIELD" id="14"/>
      <elementValue elementRef="TRIM" value="false" id="15"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="REFCOL_DATA_TYPE" id="16"/>
      <elementValue elementRef="TRIM" value="false" id="17"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="sequence_order" id="18"/>
      <elementValue elementRef="TRIM" value="false" id="19"/>
    </elementParameter>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tDBInput_1">
      <column comment="" key="false" length="30" name="FUNC" nullable="true" pattern="" precision="-1" sourceType="VARCHAR" type="id_String" originalLength="25" usefulColumn="true"/>
      <column comment="" key="false" length="50" name="ORDER_NAME" nullable="true" pattern="" precision="-1" sourceType="VARCHAR" type="id_String" originalLength="50" usefulColumn="true"/>
      <column comment="" key="false" length="50" name="REF_COLUMN" nullable="true" pattern="" precision="-1" sourceType="VARCHAR" type="id_String" originalLength="30" usefulColumn="true"/>
