    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT DISTINCT&#xD;&#xA;\&quot;GID\&quot; ,&#xD;&#xA;MIN(\&quot;MDM_ID\&quot;) AS ROW_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'SOURCE_SYSTEM' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) SOURCE_SYSTEM,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'SOURCE_SYSTEM_ID' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) SOURCE_SYSTEM_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'EIDA' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) EIDA,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'UNIFIED_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) UNIFIED_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'PASSPORT_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) PASSPORT_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'PASSPORT_ISSUE_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) PASSPORT_ISSUE_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'PASSPORT_EXPIRY_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) PASSPORT_EXPIRY_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'NAME_ARABIC' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) NAME_ARABIC,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'NAME_ENGLISH' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) NAME_ENGLISH,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'DATE_OF_BIRTH' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) DATE_OF_BIRTH,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'NATIONALITY' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) NATIONALITY,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'BIRTH_COUNTRY' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) BIRTH_COUNTRY,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'BIRTH_CITY_ARABIC' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) BIRTH_CITY_ARABIC,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'BIRTH_CITY_ENGLISH' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) BIRTH_CITY_ENGLISH,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'INDIVIDUAL_GENDER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) INDIVIDUAL_GENDER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'EMIRATES' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) EMIRATES,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'OFFICE_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) OFFICE_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'MOBILE_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) MOBILE_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'FAX_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) FAX_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'PO_BOX' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) PO_BOX,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'EMAIL' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) EMAIL,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ADDRESS' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ADDRESS,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'JOB_NAME' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) JOB_NAME,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'JOB_CODE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) JOB_CODE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENTITY_CODE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENTITY_CODE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENTITY_LABOR_OFFICE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENTITY_LABOR_OFFICE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENGAGEMENT_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENGAGEMENT_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENGAGEMENT_ISSUE_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENGAGEMENT_ISSUE_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENGAGEMENT_EXPIRY_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENGAGEMENT_EXPIRY_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'ENGAGEMENT_CARD_ACTIVE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) ENGAGEMENT_CARD_ACTIVE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'POLICY_NUMBER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) POLICY_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'POLICY_START_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) POLICY_START_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'POLICY_EXPIRY_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) POLICY_EXPIRY_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'EDUCATION_LEVEL' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) EDUCATION_LEVEL,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'RELIGION' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) RELIGION,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'MARITAL_STATUS' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) MARITAL_STATUS,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'JOB_CREATED_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) JOB_CREATED_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'CARD_TYPE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) CARD_TYPE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'CARD_CANCEL_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) CARD_CANCEL_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'GRANT_TYPE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) GRANT_TYPE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_OWNER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_OWNER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_SPONSOR' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_SPONSOR,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_AUTHORIZED' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_AUTHORIZED,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_INSURED' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_INSURED,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_PENSIONER' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_PENSIONER,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'IS_BENEFICIARY' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) IS_BENEFICIARY,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'SEQ_ID' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) SEQ_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'CREATED_DATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) CREATED_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'MDM_ROLE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) MDM_ROLE,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'BATCH_ID' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) BATCH_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN \&quot;COLUMN_NAME\&quot; = 'RUNDATE' THEN case when \&quot;COLUMN_VALUE\&quot;= 'null' then null else \&quot;COLUMN_VALUE\&quot; end  else NULL END) RUNDATE&#xD;&#xA;FROM mdm.\&quot;&quot; +   context.table_name_tmp_ConfidentMatchesFiltered  +  &quot;_Value\&quot;&#xD;&#xA;WHERE&#xD;&#xA;&#x9;\&quot;ROW_NUMBER\&quot; =1 and \&quot;MDM_ID\&quot; IS NOT NULL &#xD;&#xA; GROUP BY \&quot;GID\&quot;;&quot;"/>
