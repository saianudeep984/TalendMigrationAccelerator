    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;&#x9;GID,&#xD;&#xA;&#x9;MIN(MDM_ID) AS ROW_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'SOURCE_SYSTEM_ID' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) SOURCE_SYSTEM_ID,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'SOURCE_SYSTEM' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) SOURCE_SYSTEM,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LABOUR_OFFICE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) ENTITY_LABOUR_OFFICE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_CODE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_CODE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_NAME_ENG' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) ENTITY_NAME_ENG,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_NAME_ARABIC' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) ENTITY_NAME_ARABIC,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LICENSE_NUMBER' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) ENTITY_LICENSE_NUMBER,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_NATIONALITY' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_NATIONALITY,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_SECTION' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_SECTION,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_EMIRATES' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_EMIRATES,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_STATUS' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_STATUS,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_CLASS' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_CLASS,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_CREATED_DATE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_CREATED_DATE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LICENSE_TYPE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LICENSE_TYPE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LICENSE_PLACE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LICENSE_PLACE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_TYPE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_TYPE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LICENSE_START' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LICENSE_START,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LICENSE_END' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LICENSE_END,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_ADDRESS' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_ADDRESS,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_PHONE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_PHONE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_EMAIL' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_EMAIL,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_FAX' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_FAX,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_PO_BOX' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_PO_BOX,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_WEBSITE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_WEBSITE,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LOCATION_X' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LOCATION_X,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_LOCATION_Y' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_LOCATION_Y,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_ACTIVITY' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_ACTIVITY,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'ENTITY_CATEGORY' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS ENTITY_CATEGORY,&#xD;&#xA;&#x9;MAX(CASE WHEN COLUMN_NAME = 'MDM_ROLE' THEN case when COLUMN_VALUE= 'null' then null else COLUMN_VALUE end  else NULL END) AS MDM_ROLE&#xD;&#xA;FROM &quot; +   context.table_name_tmp_ConfidentMatchesFiltered  +  &quot;_Value&#xD;&#xA;WHERE&#xD;&#xA;&#x9;ROW_NUMBER=1 and MDM_ID IS NOT NULL &#xD;&#xA; GROUP BY GID&quot;"/>
