    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot; &#xD;&#xA;insert into mdm.individualmergedmatchinput_lkp&#xD;&#xA;SELECT &#xD;&#xA;CONCAT('GR|',mm.\&quot;SOURCE_SYSTEM\&quot;,'|',mm.\&quot;ROW_ID\&quot;) as MATCHING_ROW_ID,&#xD;&#xA;mm.\&quot;SOURCE_SYSTEM\&quot;,&#xD;&#xA;mm.\&quot;SOURCE_SYSTEM_ID\&quot;,&#xD;&#xA;mm.\&quot;EIDA\&quot;,&#xD;&#xA;mm.\&quot;UNIFIED_NUMBER\&quot;,&#xD;&#xA;mi.\&quot;INDIVIDUAL_PASSPORT_NUMBER\&quot; as PASSPORT_NUMBER,&#xD;&#xA;mi.\&quot;PASSPORT_ISSUE_DATE\&quot;,&#xD;&#xA;mi.\&quot;PASSPORT_EXPIRY_DATE\&quot;,&#xD;&#xA;mm.\&quot;INDIVIDUAL_NAME_ARABIC\&quot; as NAME_ARABIC,&#xD;&#xA;mm.\&quot;INDIVIDUAL_NAME_ENGLISH\&quot; as NAME_ENGLISH,&#xD;&#xA;mm.\&quot;INDIVIDUAL_DOB\&quot; as DATE_OF_BIRTH,&#xD;&#xA;mm.\&quot;NATIONALITY\&quot;,&#xD;&#xA;mm.\&quot;BIRTH_COUNTY_ENGLISH\&quot; as BIRTH_COUNTRY,&#xD;&#xA;mm.\&quot;BIRTH_CITY_ARABIC\&quot;,&#xD;&#xA;mm.\&quot;BIRTH_CITY_ENGLISH\&quot;,&#xD;&#xA;mm.\&quot;INDIVIDUAL_GENDER\&quot;,&#xD;&#xA;ca.\&quot;EMIRATES\&quot;,&#xD;&#xA;'' as OFFICE_NUMBER,&#xD;&#xA;ca.\&quot;PHONE\&quot; as MOBILE_NUMBER,&#xD;&#xA;ca.\&quot;FAX\&quot; as FAX_NUMBER,&#xD;&#xA;ca.\&quot;PO_BOX\&quot;,&#xD;&#xA;ca.\&quot;EMAIL\&quot;,&#xD;&#xA;ca.\&quot;ADDRESS_1\&quot; as ADDRESS,&#xD;&#xA;mrt.\&quot;JOB_NAME\&quot;,&#xD;&#xA;mrt.\&quot;JOB_NUMBER\&quot;as JOB_CODE,&#xD;&#xA;'' as ENTITY_CODE,&#xD;&#xA;'' as ENTITY_LABOR_OFFICE,&#xD;&#xA;mrt.\&quot;JOB_NUMBER\&quot;as ENGAGEMENT_NUMBER,&#xD;&#xA;mrt.\&quot;JOB_START_DATE\&quot;as ENGAGEMENT_ISSUE_DATE,&#xD;&#xA;mrt.\&quot;JOB_END_DATE\&quot;as ENGAGEMENT_EXPIRY_DATE,&#xD;&#xA;mrt.\&quot;STATUS\&quot;as ENGAGEMENT_CARD_ACTIVE,&#xD;&#xA;mi.\&quot;INDIVIDUAL_POLICY_NUMBER\&quot; as POLICY_NUMBER,&#xD;&#xA;mi.\&quot;INDIVIDUAL_POLICY_START_DATE\&quot; as POLICY_START_DATE,&#xD;&#xA;mi.\&quot;INDIVIDUAL_POLICY_EXPIRY_DATE\&quot; as POLICY_EXPIRY_DATE,&#xD;&#xA;mm.\&quot;EDUCATION_LEVEL\&quot;,&#xD;&#xA;mm.\&quot;INDIVIDUAL_RELIGION\&quot; as RELIGION,&#xD;&#xA;mm.\&quot;MARRIAGE_STATUS\&quot; as MARITAL_STATUS,&#xD;&#xA;mrt.\&quot;JOB_CREATED_DATE\&quot;,&#xD;&#xA;mrt.\&quot;CARD_TYPE\&quot;,&#xD;&#xA;mrt.\&quot;JOB_CANCEL_DATE\&quot;as CARD_CANCEL_DATE,&#xD;&#xA;mi.\&quot;GRNT_TYPE\&quot; as GRANT_TYPE,&#xD;&#xA;mi.\&quot;IS_OWNER\&quot;,&#xD;&#xA;mi.\&quot;IS_SPONSOR\&quot;,&#xD;&#xA;mi.\&quot;IS_AUTHORIZED\&quot;,&#xD;&#xA;mi.\&quot;IS_INSURED\&quot;,&#xD;&#xA;mi.\&quot;IS_PENSIONER\&quot;,&#xD;&#xA;mi.\&quot;IS_BENEFICIARY\&quot;,&#xD;&#xA;cast(mm.\&quot;SOURCE_REC_ID\&quot; as INT) as SEQ_ID,&#xD;&#xA;mm.\&quot;SOURCE_CREATED_DATE\&quot; as CREATED_DATE,&#xD;&#xA;mrt.\&quot;ROLE\&quot; as MDM_ROLE,&#xD;&#xA;mm.\&quot;MDM_STATUS\&quot;,&#xD;&#xA;mm.\&quot;ROW_ID\&quot; as GID,&#xD;&#xA;mm.\&quot;MDM_STATUS\&quot; as status,&#xD;&#xA;mm.\&quot;SOURCE_RUN_ID\&quot;as BATCH_ID,&#xD;&#xA;mm.\&quot;SOURCE_RUN_DATE\&quot;as RUNDATE&#xD;&#xA;FROM&#xD;&#xA;mdm.\&quot;MDM_MASTER_INDIVIDUAL\&quot;mm &#xD;&#xA;left join mdm.\&quot;CONTACT_ADDRESS_INDIVIDUAL\&quot; ca on mm.\&quot;ROW_ID\&quot;= ca.\&quot;ROW_ID\&quot;&#xD;&#xA;left join mdm.\&quot;MDM_INDICATORS_INDIVIDUAL\&quot; mi on mm.\&quot;ROW_ID\&quot;= mi.\&quot;ROW_ID\&quot;&#xD;&#xA;left join mdm.\&quot;MDM_INDIVIDUAL_ROLE_TYPE\&quot; mrt on mm.\&quot;ROW_ID\&quot;= mrt.\&quot;ROW_ID\&quot;&#xD;&#xA;where \&quot;TYPE\&quot;= 'INDIVIDUAL'&#xD;&#xA;union all&#xD;&#xA;SELECT &#xD;&#xA;  CONCAT('SRC|',\&quot;SOURCE_SYSTEM\&quot;,'|',\&quot;ROW_ID\&quot;) as MATCHING_ROW_ID,&#xD;&#xA;  \&quot;SOURCE_SYSTEM\&quot;, &#xD;&#xA;  \&quot;SOURCE_SYSTEM_ID\&quot;, &#xD;&#xA;  \&quot;EIDA\&quot;, &#xD;&#xA;  \&quot;UNIFIED_NUMBER\&quot;, &#xD;&#xA;  \&quot;PASSPORT_NUMBER\&quot;, &#xD;&#xA;  \&quot;PASSPORT_ISSUE_DATE\&quot;, &#xD;&#xA;  \&quot;PASSPORT_EXPIRY_DATE\&quot;, &#xD;&#xA;  \&quot;NAME_ARABIC\&quot;, &#xD;&#xA;  \&quot;NAME_ENGLISH\&quot;, &#xD;&#xA;  \&quot;DATE_OF_BIRTH\&quot;, &#xD;&#xA;  \&quot;NATIONALITY\&quot;, &#xD;&#xA;  \&quot;BIRTH_COUNTRY\&quot;, &#xD;&#xA;  \&quot;BIRTH_CITY_ARABIC\&quot;, &#xD;&#xA;  \&quot;BIRTH_CITY_ENGLISH\&quot;, &#xD;&#xA;  \&quot;INDIVIDUAL_GENDER\&quot;, &#xD;&#xA;  \&quot;EMIRATES\&quot;, &#xD;&#xA;  \&quot;OFFICE_NUMBER\&quot;, &#xD;&#xA;  \&quot;MOBILE_NUMBER\&quot;, &#xD;&#xA;  \&quot;FAX_NUMBER\&quot;, &#xD;&#xA;  \&quot;PO_BOX\&quot;, &#xD;&#xA;  \&quot;EMAIL\&quot;, &#xD;&#xA;  \&quot;ADDRESS\&quot;, &#xD;&#xA;  \&quot;JOB_NAME\&quot;, &#xD;&#xA;  \&quot;JOB_CODE\&quot;, &#xD;&#xA;  \&quot;ENTITY_CODE\&quot;, &#xD;&#xA;  \&quot;ENTITY_LABOR_OFFICE\&quot;, &#xD;&#xA;  \&quot;ENGAGEMENT_NUMBER\&quot;, &#xD;&#xA;  \&quot;ENGAGEMENT_ISSUE_DATE\&quot;, &#xD;&#xA;  \&quot;ENGAGEMENT_EXPIRY_DATE\&quot;, &#xD;&#xA;  \&quot;ENGAGEMENT_CARD_ACTIVE\&quot;, &#xD;&#xA;  \&quot;POLICY_NUMBER\&quot;, &#xD;&#xA;  \&quot;POLICY_START_DATE\&quot;, &#xD;&#xA;  \&quot;POLICY_EXPIRY_DATE\&quot;, &#xD;&#xA;  \&quot;EDUCATION_LEVEL\&quot;, &#xD;&#xA;  \&quot;RELIGION\&quot;, &#xD;&#xA;  \&quot;MARITAL_STATUS\&quot;, &#xD;&#xA;  \&quot;JOB_CREATED_DATE\&quot;, &#xD;&#xA;  \&quot;CARD_TYPE\&quot;, &#xD;&#xA;  \&quot;CARD_CANCEL_DATE\&quot;, &#xD;&#xA;  \&quot;GRANT_TYPE\&quot;, &#xD;&#xA;  \&quot;IS_OWNER\&quot;, &#xD;&#xA;  \&quot;IS_SPONSOR\&quot;, &#xD;&#xA;  \&quot;IS_AUTHORIZED\&quot;, &#xD;&#xA;  \&quot;IS_INSURED\&quot;, &#xD;&#xA;  \&quot;IS_PENSIONER\&quot;, &#xD;&#xA;  \&quot;IS_BENEFICIARY\&quot;, &#xD;&#xA;  \&quot;SEQ_ID\&quot;, &#xD;&#xA;  to_char(\&quot;CREATED_DATE\&quot;,'YYYY-MM-DD HH:MM:SS') as CREATED_DATE, &#xD;&#xA;  \&quot;MDM_ROLE\&quot;, &#xD;&#xA;  \&quot;MDM_STATUS\&quot;,&#xD;&#xA;  cast(\&quot;GID\&quot; as INT) as GID,&#xD;&#xA;  \&quot;MDM_STATUS\&quot; as status,&#xD;&#xA;  \&quot;BATCH_ID\&quot;,&#xD;&#xA;  \&quot;RUNDATE\&quot;&#xD;&#xA;FROM staging.\&quot;MDM_INDIVIDUAL_AGGREGATE\&quot;&#xD;&#xA;WHERE   \&quot;MDM_STATUS\&quot; ='Clean' and  \&quot;EIDA\&quot; IS NOT NULL ;&#xD;&#xA;&quot;&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
