  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1280" posY="480">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="java.util.List&lt;String[]> configuation=new java.util.ArrayList();&#xA;java.util.List&lt;String> dataOrder=new java.util.ArrayList();"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="//System.out.println(&quot;Confidence Weight ==>&quot; + row12.CONFIDENCE_WEIGHT);&#xA;com.artha.matching.util.MatchingFieldConfig conf = new com.artha.matching.util.MatchingFieldConfig(); &#xA;&#xA;String functionName=&quot;&quot;;&#xA;switch(row7.FUNCTION_NAME) {&#xA;  case &quot;Levenshtein&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.LEVENSHTEIN_DISTANCE.toString();&#xA;    break;&#xA;  case &quot;Exact - ignore case&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.LEVENSHTEIN_DISTANCE.toString();&#xA;    break;&#xA;  case &quot;Jaro-Winkler&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.JARO_WINKER.toString();&#xA;    break;&#xA;  case &quot;Metaphone&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.METAPHONE.toString();&#xA;    break;&#xA;  case &quot;Double Metaphone&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.DOUBLE_METAPHONE.toString();&#xA;    break;&#xA;  case &quot;Hamming&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.HAMMING.toString();&#xA;    break;&#xA;  case &quot;Soundex&quot;:&#xA;    functionName=com.artha.matching.util.MatchingFunction.SOUNDEX.toString();&#xA;    break;&#xA;  default:&#xA;    functionName=com.artha.matching.util.MatchingFunction.EXACT.toString();&#xA;} &#xA;configuation.add(new String[] {row7.INPUT_COLUMN,row7.CONFIDENCE_WEIGHT==null?&quot;1&quot;:row7.CONFIDENCE_WEIGHT,functionName});&#xA; &#xA;dataOrder.add(row7.INPUT_COLUMN);"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value="globalMap.put(&quot;matching_config&quot;, configuation);&#xA;globalMap.put(&quot;matching_data_order&quot;, dataOrder);"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaFlex_1"/>
  </node>
