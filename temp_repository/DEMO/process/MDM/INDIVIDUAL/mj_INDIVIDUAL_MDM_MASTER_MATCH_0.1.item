    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;&#x9;&#x9;CONCAT(string_agg(CONCAT('\&quot;',INPUT_COLUMN,'\&quot;'),','),',\&quot;MATCHING_ROW_ID\&quot; as ROW_ID,\&quot;GID\&quot;,\&quot;status\&quot;') as INPUT_COLUMN,&#xD;&#xA;&#x9;&#x9;string_agg(CONCAT(CONFIDENCE_WEIGHT,'.0'),',') as CONFIDENCE_WEIGHT,&#xD;&#xA;&#x9;&#x9;string_agg(&#xD;&#xA;&#x9;&#x9;case when FUNCTION_NAME ='Levenshtein' then 'com.artha.matching.util.MatchingFunction.LEVENSHTEIN_DISTANCE'&#xD;&#xA; &#x9;when FUNCTION_NAME ='Exact - ignore case' then 'com.artha.matching.util.MatchingFunction.LEVENSHTEIN_DISTANCE'&#xD;&#xA;    when FUNCTION_NAME ='Jaro-Winkler' then 'com.artha.matching.util.MatchingFunction.JARO_WINKER'&#xD;&#xA;    when FUNCTION_NAME ='Metaphone' then 'com.artha.matching.util.MatchingFunction.METAPHONE'&#xD;&#xA;    when FUNCTION_NAME ='Double Metaphone' then 'com.artha.matching.util.MatchingFunction.DOUBLE_METAPHONE'&#xD;&#xA;    when FUNCTION_NAME ='Hamming' then 'com.artha.matching.util.MatchingFunction.HAMMING'&#xD;&#xA;    when FUNCTION_NAME ='Soundex' then 'com.artha.matching.util.MatchingFunction.SOUNDEX'&#xD;&#xA;&#x9;else 'com.artha.matching.util.MatchingFunction.EXACT' end&#xD;&#xA;&#x9;&#x9;,',') as FUNCTION_NAME&#xD;&#xA;FROM &#xD;&#xA;&#x9;&#x9;mdm.job_match_group mg&#xD;&#xA;&#x9;&#x9;INNER JOIN&#xD;&#xA;&#x9;&#x9;mdm.job_matching_configuration mc&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;on mc.GROUP_ID = mg.ID&#xD;&#xA;&#x9;&#x9;INNER JOIN &#xD;&#xA;&#x9;&#x9;mdm.datamodel dm &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;on dm.id = mc.DATAMODEL_ID&#xD;&#xA;where &#xD;&#xA;&#x9;&#x9;mg.Groupname =  '&quot; +  ((String)globalMap.get(&quot;row8.GROUP_NAME&quot;))  +   &quot;'&#xD;&#xA;&#x9;&#x9;and&#x9;&#x9;dm.name = '&quot; +  ((String)globalMap.get(&quot;row8.MODEL_NAME&quot;))   +   &quot;'&#xD;&#xA;group by mc.DATAMODEL_ID&#xD;&#xA;&quot;"/>
