    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;update staging.\&quot;MDM_ENTITY_AGGREGATE\&quot; MEA&#xD;&#xA;set \&quot;GID\&quot; = A.\&quot;ROW_ID\&quot; , \&quot;MDM_STATUS\&quot; ='Mastered'&#xD;&#xA;from (&#xD;&#xA;select mm.\&quot;ROW_ID\&quot; , SC.SOURCE_ROWID,\&quot;GID\&quot;&#xD;&#xA;from (select REGEXP_SUBSTR(\&quot;ROW_ID\&quot;, '[^|]*$') as SOURCE_ROWID,REGEXP_SUBSTR(\&quot;GID\&quot;, '[^|]*$') as  MERGED_GID,\&quot;GID\&quot;&#xD;&#xA;from mdm.&quot;+context.GroupTable+&quot;) SC&#xD;&#xA;join mdm.\&quot;MDM_MASTER_ENTITY\&quot; mm on CAST(mm.\&quot;SOURCE_REC_ID\&quot; as INT) = cast(SC.MERGED_GID as INT))A&#xD;&#xA;where cast(A.SOURCE_ROWID as INT) = MEA.\&quot;ROW_ID\&quot; and A.\&quot;GID\&quot; not like 'GR%'&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
