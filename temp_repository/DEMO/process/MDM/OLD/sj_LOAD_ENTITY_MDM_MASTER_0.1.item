    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT DISTINCT&#xD;&#xA;C.\&quot;SOURCE_SYSTEM_ID\&quot;,&#xD;&#xA;C.\&quot;SOURCE_SYSTEM\&quot;,&#xD;&#xA;C.\&quot;ENTITY_CODE\&quot;,&#xD;&#xA;C.\&quot;ENTITY_NAME_ENG\&quot;,&#xD;&#xA;C.\&quot;ENTITY_NAME_ARABIC\&quot;, &#xD;&#xA;C.\&quot;PARENT_COMPANY_ID\&quot;,&#xD;&#xA;b.\&quot;ROW_ID\&quot;,&#xD;&#xA;C.\&quot;BATCH_ID\&quot;,&#xD;&#xA;C.\&quot;RUNDATE\&quot;&#xD;&#xA;from mdm.\&quot;&quot;+context.GroupTable+&quot;\&quot; a, mdm.\&quot;&quot;+context.MatchDataEntity+&quot;\&quot; b , staging.\&quot;MDM_ENTITY_AGGREGATE\&quot; c &#xD;&#xA;where CAST(REVERSE(SUBSTRING(REVERSE(a.\&quot;ROW_ID\&quot;),1, POSITION('|' in REVERSE(a.\&quot;ROW_ID\&quot;))- 1)) as INT) = b.\&quot;ROW_ID\&quot; &#xD;&#xA;and b.\&quot;ROW_ID\&quot; = c.\&quot;ROW_ID\&quot;  and C.\&quot;PARENT_COMPANY_ID\&quot; is not null and b.\&quot;GID\&quot; not like 'GR%';&#xD;&#xA;&quot;"/>
