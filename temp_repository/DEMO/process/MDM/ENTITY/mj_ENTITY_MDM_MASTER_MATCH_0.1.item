    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;  &#xD;&#xA;select &#xD;&#xA;e.\&quot;ROW_ID\&quot;,&#xD;&#xA;coalesce(e1.\&quot;ROW_ID\&quot;,e.\&quot;GID\&quot;) as \&quot;GID\&quot;,&#xD;&#xA;e.score,&#xD;&#xA;e.\&quot;Master\&quot;,&#xD;&#xA;e.\&quot;size\&quot;,&#xD;&#xA;case when e1.\&quot;ROW_ID\&quot; is not null then 'Clean' else e.\&quot;status\&quot; end as status,&#xD;&#xA;e.\&quot;groupQuality\&quot; &#xD;&#xA;from &quot;+context.MDM_MASTER_SCHEMA+&quot;.&quot;+context.MergedMatchInput_TmpTable+&quot; e &#xD;&#xA;left join (select distinct \&quot;ROW_ID\&quot;  ,\&quot;GID\&quot;  from &quot;+context.MDM_MASTER_SCHEMA+&quot;.&quot;+context.MergedMatchInput_TmpTable+&#xD;&#xA;&quot; where \&quot;ROW_ID\&quot; like 'GR%' and \&quot;GID\&quot; like 'SRC%') e1 on e.\&quot;GID\&quot; = e1.\&quot;GID\&quot;&#xD;&#xA;&quot;&#xD;&#xA;&#xD;&#xA;"/>
