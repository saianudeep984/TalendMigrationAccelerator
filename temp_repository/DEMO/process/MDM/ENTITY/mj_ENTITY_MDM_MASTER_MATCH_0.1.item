    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;mdm.\&quot;ROW_ID\&quot;,&#xD;&#xA;mdm.\&quot;SOURCE_SYSTEM_ID\&quot;, &#xD;&#xA;mdm.\&quot;SOURCE_SYSTEM\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_LABOUR_OFFICE\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_CODE\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_NAME_ENG\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_NAME_ARABIC\&quot;, &#xD;&#xA;'' as \&quot;ENTITY_NAME_IDENTIFIER\&quot;,&#xD;&#xA;mrt.\&quot;ENTITY_LICENSE_NUMBER\&quot;, &#xD;&#xA;mdm.\&quot;NATIONALITY\&quot; as \&quot;ENTITY_NATIONALITY\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_SECTION\&quot;, &#xD;&#xA;ca.\&quot;EMIRATES\&quot; as \&quot;ENTITY_EMIRATES\&quot;, &#xD;&#xA;mrt.\&quot;STATUS\&quot; as \&quot;ENTITY_STATUS\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_CLASS\&quot;, &#xD;&#xA;mdm.\&quot;SOURCE_CREATED_DATE\&quot; as \&quot;ENTITY_CREATED_DATE\&quot;, &#xD;&#xA;mrt.\&quot;ENTITY_LICENSE_TYPE\&quot;, &#xD;&#xA;mrt.\&quot;ENTITY_LICENSE_LOCATION\&quot; as \&quot;ENTITY_LICENSE_PLACE\&quot;, &#xD;&#xA;mdm.\&quot;ENTITY_TYPE\&quot;, &#xD;&#xA;mrt.\&quot;ENTITY_LICENSE_START_DATE\&quot; as \&quot;ENTITY_LICENSE_START\&quot;, &#xD;&#xA;mrt.\&quot;ENTITY_LICENSE_END_DATE\&quot; as \&quot;ENTITY_LICENSE_END\&quot;, &#xD;&#xA;ca.\&quot;ADDRESS_1\&quot; as \&quot;ENTITY_ADDRESS\&quot;, &#xD;&#xA;ca.\&quot;PHONE\&quot; as \&quot;ENTITY_PHONE\&quot;, &#xD;&#xA;ca.\&quot;EMAIL\&quot; as \&quot;ENTITY_EMAIL\&quot;, &#xD;&#xA;ca.\&quot;FAX\&quot; as \&quot;ENTITY_FAX\&quot;, &#xD;&#xA;ca.\&quot;PO_BOX\&quot; as \&quot;ENTITY_PO_BOX\&quot;, &#xD;&#xA;ca.\&quot;WEBSITE\&quot; as \&quot;ENTITY_WEBSITE\&quot;, &#xD;&#xA;ca.\&quot;LATITUDE\&quot; as \&quot;ENTITY_LOCATION_X\&quot;, &#xD;&#xA;ca.\&quot;LONGITUDE\&quot; as \&quot;ENTITY_LOCATION_Y\&quot;, &#xD;&#xA;mi.\&quot;ENTITY_ACTIVITY\&quot;, &#xD;&#xA;mi.\&quot;ENTITY_CATEGORY\&quot;, &#xD;&#xA;0 as \&quot;SEQ_ID\&quot;, &#xD;&#xA;mdm.\&quot;SOURCE_RUN_ID\&quot; as \&quot;BATCH_ID\&quot;, &#xD;&#xA;mdm.\&quot;SOURCE_RUN_DATE\&quot; as \&quot;RUNDATE\&quot;, &#xD;&#xA;mrt.\&quot;ROLE\&quot; as \&quot;MDM_ROLE\&quot;, &#xD;&#xA;'mastered' as \&quot;MDM_STATUS\&quot;, &#xD;&#xA;mdm.\&quot;ROW_ID\&quot; as \&quot;GID\&quot;&#xD;&#xA;FROM \&quot;mdm\&quot;.\&quot;MDM_MASTER_ENTITY\&quot; mdm&#xD;&#xA;left join (select * from \&quot;mdm\&quot;.\&quot;RELATIONSHIP_TABLE_ENTITY\&quot; union select * from mdm.\&quot;ENTITY_RELATIONSHIP_SELF\&quot;) rt on mdm.\&quot;ROW_ID\&quot; =rt.\&quot;PARENT_ROW_ID\&quot; &#xD;&#xA;left join \&quot;mdm\&quot;.\&quot;MDM_INDICATOR_ENTITY\&quot; mi on mdm.\&quot;ROW_ID\&quot; =\&quot;MDM_MASTER_ROW_ID\&quot;  &#xD;&#xA;left join \&quot;mdm\&quot;.\&quot;MDM_ENTITY_ROLE_TYPE\&quot; mrt on mdm.\&quot;ROW_ID\&quot; =mrt.\&quot;MDM_MASTER_ROW_ID\&quot; &#xD;&#xA;left join \&quot;mdm\&quot;.\&quot;CONTACT_ADDRESS_ENTITY\&quot; ca on mdm.\&quot;ROW_ID\&quot; =ca.\&quot;MDM_MASTER_ROW_ID\&quot; &#xD;&#xA;WHERE 1=0&#xD;&#xA;&quot;"/>
