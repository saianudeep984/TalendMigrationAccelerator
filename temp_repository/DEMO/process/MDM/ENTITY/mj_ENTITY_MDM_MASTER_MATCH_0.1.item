    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;&#x9;&#x9;mc.ID,&#xD;&#xA;&#x9;&#x9;INPUT_COLUMN,&#xD;&#xA;&#x9;&#x9;MATCHING_TYPE,&#xD;&#xA;&#x9;&#x9;CONFIDENCE_WEIGHT,&#xD;&#xA;&#x9;&#x9;HANDLE_NULL,&#xD;&#xA;&#x9;&#x9;mc.DATAMODEL_ID,&#xD;&#xA;&#x9;&#x9;COMPONENT_ID,&#xD;&#xA;&#x9;&#x9;ENTITY_NAME,&#xD;&#xA;&#x9;&#x9;FUNCTION_NAME,&#xD;&#xA;&#x9;&#x9;ACTUAL_FIELD&#xD;&#xA;FROM &#xD;&#xA;&#x9;&#x9;mdm.job_match_group mg&#xD;&#xA;&#x9;&#x9;INNER JOIN&#xD;&#xA;&#x9;&#x9;mdm.job_matching_configuration mc&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;on mc.GROUP_ID = mg.ID&#xD;&#xA;&#x9;&#x9;INNER JOIN &#xD;&#xA;&#x9;&#x9;mdm.datamodel dm &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;on dm.id = mc.DATAMODEL_ID&#xD;&#xA;where &#xD;&#xA;&#x9;&#x9;mg.Groupname = '&quot; +  ((String)globalMap.get(&quot;row8.GROUP_NAME&quot;))  +   &quot;'&#xD;&#xA;&#x9;&#x9;and&#x9;&#x9;dm.name = '&quot; +  ((String)globalMap.get(&quot;row8.MODEL_NAME&quot;))   +   &quot;'&#xD;&#xA;&quot;"/>
