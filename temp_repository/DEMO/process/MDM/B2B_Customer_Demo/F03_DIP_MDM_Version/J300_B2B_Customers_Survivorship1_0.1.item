    <elementParameter field="MEMO_SQL" name="QUERY" value="/****** Script for SelectTopNRows command from SSMS  ******/&#xD;&#xA;&quot;&#xD;&#xA;SELECT &#xD;&#xA;&#x9;   [FUNC]&#xD;&#xA;      ,[ORDER]&#xD;&#xA;     ,[REFERENCE_COLUMN]&#xD;&#xA;      ,[VALUE]&#xD;&#xA;      ,[TARGET_COLUMN]&#xD;&#xA;      ,[IGNORE_BLANKS]&#xD;&#xA;      ,[REFERENCE_ACTUAL_FIELD]&#xD;&#xA;      ,[TARGET_ACTUAL_FIELD]&#xD;&#xA;  FROM &#xD;&#xA;&#x9;[mdmprod_test].[mdm].[datamodel] dm &#xD;&#xA;&#x9;inner join&#xD;&#xA;&#x9;[mdmprod_test].[mdm].[job_merging_configuration] s on&#xD;&#xA;&#x9;&#x9;[DATAMODEL_ID] = dm.id&#xD;&#xA;&#x9;inner join [mdmprod_test].[mdm].[job_merge_rule] mr on&#xD;&#xA;&#x9;&#x9;mr.id = s.rule_id&#xD;&#xA;  where &#xD;&#xA;&#x9;dm.name = '&quot;  +  context.Data_Model_Name  + &quot;'  &#xD;&#xA;&#x9;and &#xD;&#xA;&#x9;mr.[rulename]='&quot;  +  context.Rule_Name   + &quot;'&#xD;&#xA;  order by&#xD;&#xA;&#x9;Sequence_order&#xD;&#xA;&#xD;&#xA;&#x9;&#xD;&#xA;&quot;"/>
