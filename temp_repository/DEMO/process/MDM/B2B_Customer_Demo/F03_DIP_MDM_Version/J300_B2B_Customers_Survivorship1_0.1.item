    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_15" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="context.rule_table_query = context.rule_table_query&#xA; +&quot; JOIN ( &quot;&#xA; &#x9;+&quot; SELECT &quot;&#xA;&#x9;&#x9;+ context.group_identifier_column + &quot; as GID, &quot;&#xA;&#x9;&#x9;+ ((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;)) &#xA;&#x9;&#x9;+&quot;, count(&quot; + ((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))+ &quot;) as ctr &quot; &#xA;&#x9;+ &quot;FROM &quot;&#xA;&#x9;&#x9;+ context.table_name_tmp_ConfidentMatchesFiltered +&#x9;&quot; AS tmp_CMF &quot; &#xA;&#x9;+   &quot;   WHERE &quot;&#xA;&#x9;&#x9;&#x9;+ ((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))+ &quot; IS NOT NULL &quot;   &#xA;&#x9;+ &quot;Group by &quot; &#xA;&#x9;+ &quot;&#x9;&#x9;GID, &quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))&#xA;&#x9;+&quot;) ValCount on &quot;&#xA;&#x9;+ &quot;&#x9;&#x9;ValCount.&quot;+context.group_identifier_column+&quot; = &quot;+ context.table_name_tmp_ConfidentMatchesFiltered +&quot;.&quot;+context.group_identifier_column&#xA;&#x9;+&quot;      and ValCount.&quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))+&quot; = &quot;+context.table_name_tmp_ConfidentMatchesFiltered +&#x9;&quot;.&quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))&#xA; +&quot; JOIN ( &quot;&#xA;&#x9;+&quot; SELECT &quot; &#xA;&#x9;&#x9;+ context.group_identifier_column+&quot; as GID &quot;&#xA;&#x9;&#x9;+ &quot;&#x9;, Max(Ctr) MaxCtr &quot;&#xA;    +&quot; FROM &quot;&#xA;&#x9;+ &quot;    (&quot;&#xA;&#x9;&#x9;+ &#x9;&quot;&#x9;SELECT&#x9;&quot;&#xA;&#x9;&#x9;&#x9;&#x9;+&#x9;context.group_identifier_column+&quot; as GID &quot;&#xA;&#x9;&#x9;&#x9;&#x9;+ &quot;&#x9;, &quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))&#xA;&#x9;&#x9;&#x9;&#x9;+ &quot;&#x9;, count(&quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))+&quot;) as ctr &quot; &#xA;&#x9;&#x9;+&#x9;&quot;&#x9;FROM &quot;&#xA;&#x9;&#x9;&#x9;&#x9;+&#x9;context.table_name_tmp_ConfidentMatchesFiltered +&#x9;&quot;  tmp_CMF &quot;&#xA;&#x9;&#x9;+   &quot;   WHERE &quot;&#xA;&#x9;&#x9;&#x9;&#x9;+ ((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))+ &quot; IS NOT NULL &quot;   &#xA;&#x9;&#x9;+&#x9;&quot;&#x9;Group by GID, &quot;+((String)globalMap.get(&quot;out3.REF_COLUMN_PREV&quot;))&#xA;&#x9;&#x9;+&quot; ) ValCount1 &quot;&#xA;&#x9;+ &quot;group by GID &quot; &#xA; +&quot; ) as MOST_COMMON &quot; &#xA; +&quot;       on MOST_COMMON.GID = ValCount.GID &quot;&#xA; +&quot;        and MOST_COMMON.MaxCtr =  ValCount.ctr&quot;&#x9;;&#xA;&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
