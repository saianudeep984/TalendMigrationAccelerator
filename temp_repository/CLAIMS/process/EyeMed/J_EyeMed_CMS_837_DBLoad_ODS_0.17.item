    <elementParameter field="MEMO_MESSAGE" name="MESSAGE" value="&quot;&lt;html>&#xD;&#xA;&lt;head>&#xD;&#xA;&lt;style> table { width:auto; } table, th, td { border: 1px solid black; &#xD;&#xA;border-collapse: collapse; } th, td { padding: 2px; text-align: left; &#xD;&#xA;font-size:15px; } table.names tr:nth-child(even) { background-color: #eee; }  &#xD;&#xA;table.names tr:nth-child(odd) { background-color:#fff; } table.names th { &#xD;&#xA;background-color: #666633; color: white } &lt;/style>&lt;/head>&#xD;&#xA;&#xD;&#xA;&lt;body>&#xD;&#xA;&lt;P>EyeMed CMS 837  files got Downloaded  successfully and &#xD;&#xA;&#xD;&#xA;&lt;a href='&quot;+context.TNTPath+context.TNTENV+&quot;EyeMed/INBOUND/SupENCNTR_Archive'>&lt;strong>&lt;b>New file is available in Inbound (Click here)&lt;/b>&lt;/strong>&lt;/a>&#xD;&#xA;&lt;/b>  folder. &lt;/p>&#xD;&#xA;&lt;br>&#xD;&#xA;&lt;h5> EyeMed CMS 837 Claims Raw file counts &lt;/h5>&#xD;&#xA;&lt;table class='names' rules='rows'>&#xD;&#xA;&lt;tr>&lt;th>FileName&lt;/th>&lt;th>ProviderCount&lt;/th>&lt;th>SubscriberCount&lt;/th>&lt;th>ClaimsCount&lt;/th>&lt;th>ServiceCount&lt;/th>&lt;/tr>&lt;tr>&lt;td>&quot;+context.L_FileName.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_Provider.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_Subscriber.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_Claims.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_Service.trim()+&quot;&lt;/td>&lt;/tr>&#xD;&#xA;&lt;/table>&#xD;&#xA;&lt;h5> EyeMed CMS 837 Claims Loaded to PartnerExchange DB &amp; Counts &lt;/h5>&#xD;&#xA;&lt;/p>&#xD;&#xA;&lt;table class='names' rules='rows'>&#xD;&#xA;&lt;tr>&lt;th>FileName&lt;/th>&lt;th>EyeMed CMS Provider&lt;/th>&lt;th>EyeMed CMS Subscriber&lt;/th>&lt;th>EyeMed CMS Claims&lt;/th>&lt;th>EyeMed CMS ProfessionalService&lt;/th>&lt;/tr>&lt;tr>&lt;td>&quot;+context.L_T_FileName.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_CTSProvider.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_CTSSubscriber.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_CTSClaims.trim()+&quot;&lt;/td>&lt;td>&quot;+context.L_CTSService.trim()+&quot;&lt;/td>&lt;/tr>&#xD;&#xA;&lt;/table>&#xD;&#xA;&lt;br>&#xD;&#xA;&lt;p>Automated Email from Talend. Please do not reply to this e-mail.&lt;/p>&#xD;&#xA;&#xD;&#xA;&lt;/body>&#xD;&#xA;&lt;/html>&quot;"/>
