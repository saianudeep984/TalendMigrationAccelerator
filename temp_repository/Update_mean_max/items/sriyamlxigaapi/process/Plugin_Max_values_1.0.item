    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;AA.companyid,&#xD;&#xA;ROUND(AVG(P1),2) AS 'Mean Total Visits to Website',&#xD;&#xA;ROUND(AVG(P1)+3*STDDEV(P1),2) AS 'MAX Total Visits to Website',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P2),2) AS 'Mean Total Page Views',&#xD;&#xA;ROUND(AVG(P2)+3*STDDEV(P2),2) AS 'MAX Total Page Views',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P2/P1),2) AS 'Mean Page Views Per Visit',&#xD;&#xA;ROUND(AVG(P2/P1)+3*(STDDEV(P2/P1)),2)AS 'MAX Page Views Per Visit',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4),2) AS 'Mean Time On Page',&#xD;&#xA;ROUND(AVG(P4)+3*STDDEV(P4),2) AS 'MAX Time On Page',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4/P1),2) AS 'Mean Total Time Spent Per Session',&#xD;&#xA;ROUND(AVG(P4/P1)+3*STDDEV(P4/P1),2) AS 'MAX Total Time Spent Per Session',&#xD;&#xA;&#xD;&#xA;ROUND(AVG((P6/P1)*100),2) AS 'AVG Bounce Rate',&#xD;&#xA;ROUND(AVG((P6/P1)*100)+3*STDDEV((P6/P1)*100),2)AS 'MAX Bounce Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG((P7/P1)*100),2) AS 'AVG Checkout Abandonment Rate',&#xD;&#xA;ROUND(AVG((P7/P1)*100)+3*STDDEV((P7/P1)*100),2) AS 'MAX Checkout Abandonment Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG((P8/P1)*100),2) AS 'AVG Task Completion Rate',&#xD;&#xA;ROUND(AVG((P8/P1)*100)+3*STDDEV((P8/P1)*100),2) AS 'MAX Task Completion Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P9),2) AS 'Mean Number of Clickable events',&#xD;&#xA;ROUND(AVG(P9)+3*STDDEV(P9),2) AS 'MAX Number of Clickable events',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P10),2) AS 'Mean Number Of Product Pages Viewed',&#xD;&#xA;ROUND(AVG(P10)+3*STDDEV(P10),2) AS 'MAX Number Of Product Pages Viewed',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P11),2) AS 'Mean Page Load Per Refresh Time',&#xD;&#xA;ROUND(AVG(P11)+3*STDDEV(P11),2) AS 'MAX Page Load Per Refresh Time',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4/P2 ),2) AS 'Mean Avg Page Time',&#xD;&#xA;ROUND(AVG(P4/P2 )+3*STDDEV(P4/P2 ),2) AS 'MAX Avg Page Time',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P13),2) AS 'Mean Number of scrolls per session',&#xD;&#xA;ROUND(AVG(P13)+3*STDDEV(P13)) AS 'MAX Number of scrolls per session',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P14)) AS 'Mean Search',&#xD;&#xA;ROUND(AVG(P14)+3*STDDEV(P14),2) AS 'MAX Search',&#xD;&#xA;&#xD;&#xA;ROUND(AVG((P1/TOT)*100),2) AS 'AVG Visitor Loyalty',&#xD;&#xA;ROUND(AVG(P1/TOT*100)+3*STDDEV(P1/TOT*100),2) AS 'MAX Visitor Loyalty',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P16),2) AS 'Mean Top Exit Pages',&#xD;&#xA;ROUND(AVG(P16)+3*STDDEV(P16),2) AS 'MAX Top Exit Pages'&#xD;&#xA;&#xD;&#xA;FROM&#xD;&#xA;(&#xD;&#xA;SELECT&#xD;&#xA;'1' AS ID,s.companyid,&#xD;&#xA;cookiename,&#xD;&#xA;Count(distinct(sessionid)) AS 'P1',&#xD;&#xA;SUM( CASE WHEN paramid='2' THEN paramvalue ELSE 0 END) AS 'P2',&#xD;&#xA;SUM( CASE WHEN paramid='3' THEN paramvalue ELSE 0 END) AS 'P3',&#xD;&#xA;SUM( CASE WHEN paramid='4' THEN paramvalue ELSE 0 END) AS 'P4',&#xD;&#xA;SUM( CASE WHEN paramid='5' THEN paramvalue ELSE 0 END) AS 'P5',&#xD;&#xA;SUM( CASE WHEN paramid='6' THEN paramvalue ELSE 0 END) AS 'P6',&#xD;&#xA;SUM( CASE WHEN paramid='7' THEN paramvalue ELSE 0 END) AS 'P7',&#xD;&#xA;SUM( CASE WHEN paramid='8' THEN paramvalue ELSE 0 END) AS 'P8',&#xD;&#xA;SUM( CASE WHEN paramid='9' THEN paramvalue ELSE 0 END) AS 'P9',&#xD;&#xA;SUM( CASE WHEN paramid='10' THEN paramvalue ELSE 0 END) AS 'P10',&#xD;&#xA;SUM( CASE WHEN paramid='11' THEN paramvalue ELSE 0 END) AS 'P11',&#xD;&#xA;SUM( CASE WHEN paramid='12' THEN paramvalue ELSE 0 END) AS 'P12',&#xD;&#xA;SUM( CASE WHEN paramid='13' THEN paramvalue ELSE 0 END) AS 'P13',&#xD;&#xA;SUM( CASE WHEN paramid='14' THEN paramvalue ELSE 0 END) AS 'P14',&#xD;&#xA;SUM( CASE WHEN paramid='15' THEN paramvalue ELSE 0 END) AS 'P15',&#xD;&#xA;SUM( CASE WHEN paramid='16' THEN paramvalue ELSE 0 END) AS 'P16',&#xD;&#xA;A.SumCookies AS 'TOT'&#xD;&#xA;FROM&#xD;&#xA;(&#xD;&#xA; select sessionid,companyid,cookiename,paramid, paramvalue&#xD;&#xA; FROM plugin_master_data&#xD;&#xA; WHERE companyid ='&quot;+context.companyid+&quot;' AND sessiontimestamp BETWEEN '&quot;+context.startdate+&quot;' AND '&quot;+context.enddate+&quot;'&#xD;&#xA; ORDER BY cookiename,paramid ASC&#xD;&#xA;) s,(select companyid,COUNT(cookiename) as SumCookies FROM plugin_master_data&#xD;&#xA;WHERE companyid = '&quot;+context.companyid+&quot;' and paramid=2 AND sessiontimestamp BETWEEN  '&quot;+context.startdate+&quot;' AND '&quot;+context.enddate+&quot;'&#xD;&#xA;GROUP BY companyid) A&#xD;&#xA;WHERE s.companyid=A.companyid&#xD;&#xA;GROUP BY cookiename) AA&#xD;&#xA;GROUP BY companyid;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
