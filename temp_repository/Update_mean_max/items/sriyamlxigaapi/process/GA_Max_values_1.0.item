    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;ROUND(AVG(P1),2) as 'Mean Total Visits to Website',&#xD;&#xA;ROUND(AVG(P1)+3*STDDEV(P1),2) as 'MAX Total Visits to Website',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P2),2) as 'Mean Total Page Views',&#xD;&#xA;ROUND(AVG(P2)+3*STDDEV(P2),2) as 'MAX Total Page Views',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P2/IF(P1=0,1,P1)),2) AS 'Mean Page Views per Visit',&#xD;&#xA;ROUND(AVG(P2/IF(P1=0,1,P1))+3*STDDEV(P2/IF(P1=0,1,P1)),2)  AS 'MAX Page Views per Visit',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4),2) AS 'Mean Total Time on all Pages',&#xD;&#xA;ROUND(AVG(P4)+3*STDDEV(P4),2) AS 'MAX Total Time on all Pages',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4/IF(P1=0,1,P1)),2)  AS 'Mean Avg Visit Duration',&#xD;&#xA;ROUND(AVG(P4/IF(P1=0,1,P1))+3* STDDEV(P4/IF(P1=0,1,P1)),2) AS 'MAX Avg Visit Duration',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P6),2) AS 'AVG Bounce Rate',&#xD;&#xA;ROUND(AVG(P6)+3*STDDEV(P6),2) AS 'MAX Bounce Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P7),2) AS 'AVG Checkout Abandonment Rate',&#xD;&#xA;ROUND(AVG(P7)+3*STDDEV(P7),2) AS 'MAX Checkout Abandonment Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P15-P19),2)  AS 'Mean Total Repeat Users',&#xD;&#xA;ROUND(AVG(P15-P19)+3*STDDEV(P15-P19),2)  AS 'MAX Total Repeat Users',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P19/IF(P15-P19=0 ,1 ,P15-P19)),2) AS 'Mean New Vs Returned Visitors',&#xD;&#xA;ROUND(AVG(P19/IF(P15-P19=0 ,1 ,P15-P19))+3*STDDEV(P19/IF(P15-P19=0 ,1 ,P15-P19)),2) AS 'MAX New Vs Returned Visitors',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P10),2) AS 'Mean Page Exits',&#xD;&#xA;ROUND(AVG(P10)+3*STDDEV(P10),2) AS 'MAX Page Exits',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P11),2) AS 'AVG Task Completion Rate',&#xD;&#xA;ROUND(AVG(P11)+3*STDDEV(P11),2) AS 'MAX Task Completion Rate',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P12),2) AS 'Mean Percent Visitors who view product pages',&#xD;&#xA;ROUND(AVG(P12)+3*STDDEV(P12),2) AS 'MAX Percent Visitors who view product pages',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P13),2) AS 'Mean Total Page Load Time',&#xD;&#xA;ROUND(AVG(P13)+3*STDDEV(P13),2) AS 'MAX Total Page Load Time',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P1/P15),2)  AS 'Mean Visits Per User',&#xD;&#xA;ROUND(AVG(P1/P15)+3*STDDEV(P1/P15),2)  AS 'MAX Visits Per User',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P15),2) AS 'Mean Total Visitors',&#xD;&#xA;ROUND(AVG(P15)+3*STDDEV(P15),2) AS 'MAX Total Visitors',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P4/P2),2)  AS 'Mean Avg. Time On Page',&#xD;&#xA;ROUND(AVG(P4/P2)+3*STDDEV(P4/P2),2)  AS 'MAX Avg. Time On Page',&#xD;&#xA;&#xD;&#xA;ROUND(AVG((P15-P19)/P15*100),2) AS 'AVG Visitor Loyalty',&#xD;&#xA;ROUND(AVG((P15-P19)/P15*100)+3*STDDEV((P15-P19)/P19*100),2) AS 'MAX Visitor Loyalty',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P18),2) AS 'Mean Percent of people who search on your site',&#xD;&#xA;ROUND(AVG(P18)+3*STDDEV(P18),2) AS 'MAX Percent of people who search on your site',&#xD;&#xA;&#xD;&#xA;ROUND(AVG(P19),2) AS 'Mean Total New Users',&#xD;&#xA;ROUND(AVG(P19)+3*STDDEV(P19),2) AS 'MAX Total New Users'&#xD;&#xA;&#xD;&#xA;FROM&#xD;&#xA;(&#xD;&#xA;SELECT&#xD;&#xA;dates,hours,&#xD;&#xA;SUM( CASE WHEN paramid='1' THEN paramvalues ELSE 0 END) AS 'P1',&#xD;&#xA;SUM( CASE WHEN paramid='2' THEN paramvalues ELSE 0 END) AS 'P2',&#xD;&#xA;SUM( CASE WHEN paramid='3' THEN paramvalues ELSE 0 END) AS 'P3',&#xD;&#xA;SUM( CASE WHEN paramid='4' THEN paramvalues ELSE 0 END) AS 'P4',&#xD;&#xA;SUM( CASE WHEN paramid='5' THEN paramvalues ELSE 0 END) AS 'P5',&#xD;&#xA;SUM( CASE WHEN paramid='6' THEN paramvalues ELSE 0 END) AS 'P6',&#xD;&#xA;SUM( CASE WHEN paramid='7' THEN paramvalues ELSE 0 END) AS 'P7',&#xD;&#xA;SUM( CASE WHEN paramid='8' THEN paramvalues ELSE 0 END) AS 'P8',&#xD;&#xA;SUM( CASE WHEN paramid='9' THEN paramvalues ELSE 0 END) AS 'P9',&#xD;&#xA;SUM( CASE WHEN paramid='10' THEN paramvalues ELSE 0 END) AS 'P10',&#xD;&#xA;SUM( CASE WHEN paramid='11' THEN paramvalues ELSE 0 END) AS 'P11',&#xD;&#xA;SUM( CASE WHEN paramid='12' THEN paramvalues ELSE 0 END) AS 'P12',&#xD;&#xA;SUM( CASE WHEN paramid='13' THEN paramvalues ELSE 0 END) AS 'P13',&#xD;&#xA;SUM( CASE WHEN paramid='14' THEN paramvalues ELSE 0 END) AS 'P14',&#xD;&#xA;SUM( CASE WHEN paramid='15' THEN paramvalues ELSE 0 END) AS 'P15',&#xD;&#xA;SUM( CASE WHEN paramid='16' THEN paramvalues ELSE 0 END) AS 'P16',&#xD;&#xA;SUM( CASE WHEN paramid='17' THEN paramvalues ELSE 0 END) AS 'P17',&#xD;&#xA;SUM( CASE WHEN paramid='18' THEN paramvalues ELSE 0 END) AS 'P18',&#xD;&#xA;SUM( CASE WHEN paramid='19' THEN paramvalues ELSE 0 END) AS 'P19'&#xD;&#xA;FROM&#xD;&#xA;(&#xD;&#xA; select companyid,dates,hours,paramid, paramvalues&#xD;&#xA; FROM ga_master_data&#xD;&#xA; WHERE companyid = '&quot;+context.companyid+&quot;' AND DATES BETWEEN '&quot;+context.startdate+&quot;' AND '&quot;+context.enddate+&quot;'&#xD;&#xA; ORDER BY dates,hours,paramid ASC&#xD;&#xA;) s&#xD;&#xA;GROUP BY dates,hours)AA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
